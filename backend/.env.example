# =====================
# DB (docker-compose + FastAPI 공통)
# =====================
POSTGRES_USER=molib
POSTGRES_PASSWORD=molib
POSTGRES_DB=molib
DATABASE_URL=postgresql://molib:molib@db:5432/molib

# =====================
# JWT
# =====================
# JWT_SECRET_KEY 생성: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your-secret-key-here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# =====================
# bcrypt
# =====================
BCRYPT_ROUNDS=12

# =====================
# CORS
# =====================
# 쉼표로 구분. 프로덕션에서는 실제 도메인으로 교체할 것
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081

# =====================
# 외부 API
# =====================
TMDB_API_KEY=your-tmdb-api-key
SPOTIFY_CLIENT_ID=your-spotify-client-id
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret
ALADIN_TTB_KEY=your-aladin-ttb-key